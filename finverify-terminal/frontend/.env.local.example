# FinVerify Terminal — Frontend Environment Variables
# Copy to .env.local and fill in your values

# Backend API URL (HuggingFace Space)
NEXT_PUBLIC_API_URL=https://aadi2026-finverify-api.hf.space

# WebSocket URL (auto-derived from API_URL if not set)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Finnhub API key (free tier — https://finnhub.io, 60 calls/min)
# Get a free key at https://finnhub.io and paste below
NEXT_PUBLIC_FINNHUB_KEY=

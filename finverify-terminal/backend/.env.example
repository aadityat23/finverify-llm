# FinVerify Terminal — Backend Environment Variables
# Copy to .env and fill in your values

# HuggingFace API Token (for model inference)
HF_TOKEN=your_token_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://finverify-terminal.vercel.app

# Market data cache TTL in seconds (rate limit per symbol)
MARKET_CACHE_TTL=10

# Supabase (free tier — https://supabase.com)
# Used for persistent query history (Session 12A)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# Pinecone (vector store for RAG pipeline)
PINECONE_API_KEY=your_pinecone_api_key_here
